{
  "expo": {
    "name": "StockClarify",
    "slug": "stockclarify",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "stockclarify",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1628"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.stockclarify.app",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "StockClarify uses the camera only if you choose to attach a photo to feedback.",
        "NSPhotoLibraryUsageDescription": "StockClarify accesses your photo library only if you choose to attach a photo to feedback.",
        "NSPhotoLibraryAddUsageDescription": "StockClarify saves shareable insight cards to your photo library when you tap Save Image.",
        "NSLocationWhenInUseUsageDescription": "StockClarify uses your approximate location only to show market hours and trading sessions relevant to your region."
      }
    },
    "android": {
      "package": "com.stockclarify.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0A1628"
      },
      "permissions": []
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      ["expo-router", {}],
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#0A1628",
          "sounds": []
        }
      ],
      "react-native-purchases",
      "expo-apple-authentication"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    }
  }
}
